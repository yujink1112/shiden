    { "type": "role", "role": "BGM", "names": ["あしなが☆おにいさん様", "3104様", "トラ猫様", "ゆう様", "まんぼう二等兵様", "氷石彩亜様", "南雲莉翠様", "Tスタ様", "VS Qplus+様", "デジファミ音楽堂様"] },
    { "type": "space", "height": 60 },
    { "type": "text", "content": "© 2026 Shiden Games" },
    { "type": "space", "height": 150 },
    { "type": "afterstory", "title": "ブッパー", "icon": "ブッパー", "text": "キャプテン亡き後も、エーヴィス海賊団は存続する。\n砲術を極めた彼の腕前は、イスパニア海軍に大いに恐れられた。" },
    { "type": "space", "height": 100 },
    { "type": "afterstory", "title": "エーアイン", "icon": "エーアイン", "text": "ウェルズランドに帰国し、船を降りる。\nその後は吟遊詩人となり、レミエルとエーヴィスの冒険譚を各地に残していった。" },
    { "type": "space", "height": 100 },
    { "type": "afterstory", "title": "マルトー", "icon": "マルトー", "text": "魔女の末裔である彼は、最後までエーヴィスの船に乗り続けた。\n彼の遺言を継ぎ、終生イスパニア以外の船を襲わなかったという。" },
    { "type": "space", "height": 100 },
    { "type": "afterstory", "title": "エーヴィス", "icon": "エーヴィス", "text": "その魂は、故郷の海に還った。\n彼が誇った団員達を除いて、その場所を知る者はいない。" },
    { "type": "space", "height": 100 },
    { "type": "afterstory", "title": "ラスト・ウィッチ号", "icon": "ウィッチ", "text": "かつての魔女は、祝福を持って国に迎え入れられた。\n待ち兼ねていた至福の時。それは、海軍士官50人による全身大洗浄祭だった。" },
    { "type": "space", "height": 100 },
    { "type": "afterstory", "title": "ルーサー", "icon": "ルーサー", "text": "かくして、レミエル海賊団は《アノマ》からの帰還を果たした。\n家出同然に別れた両親との和解に涙し、やがて冒険の旅に戻った。" },
    { "type": "space", "height": 100 },
    { "type": "afterstory", "title": "アダム", "icon": "アダム", "text": "\"大鴉\"は、密やかに元の籠へと戻った。\nゴルゾア海域の生き残りと再会したことで、彼の願いは叶えられた。" },
    { "type": "space", "height": 100 },
    { "type": "afterstory", "title": "リザベル", "icon": "リザベル", "text": "オルゴールの中で、毎日レミエルに不満を垂れている。\n毎晩、修道女のように神様に祈っている。届くことはあるのだろうか。\n「もう悪さはしないから、彼のそばにいさせてください。」" },
    { "type": "space", "height": 100 },
    { "type": "afterstory", "title": "レミエル", "icon": "レミエル", "text": "幻の島から有形無形の財宝を持ち帰り、女王陛下に謁見した。\n《アノマ》で得た冷凍保存の技術は、国の物流に革命をもたらした。\nレッド家は伯爵の爵位を与えられ、レミエル自身も名門貴族として長く内政に励むことになる。\n\nそれは、《アノマ》から持ち帰った\"レンダリングプラズマ\"による偽物だった。\n再び海賊団を結成し、4人の仲間と共に未知なる大陸を目指す――！" },
    { "type": "space", "height": 200 },
    { "type": "afterstory", "title": "あなた", "icon": "あなた", "text": "幻の島《アノマ》の女王にして、物語の観測者。\nこのゲームを最後までプレイしてくれたことに、この上ない感謝を捧げます。" },


    { "type": "space", "height": 200 },
    { "type": "text", "content": "Thank you for playing!" },
    { "type": "space", "height": 500 }
  ]
}
